<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Fork eklem durumunu Gazebo → /joint_states'e yayımlar (TF güncel kalır) -->
    <gazebo>
        <plugin name="fork_joint_state_pub" filename="libgazebo_ros_joint_state_publisher.so">
            <update_rate>30</update_rate>
            <joint_name>fork_carriage_joint</joint_name>
        </plugin>
    </gazebo>

</robot>
