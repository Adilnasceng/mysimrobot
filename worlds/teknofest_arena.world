    <!-- ═══════════════════════════════════════════════════════════════════
         QR ZEMIN MARKERLERİ q1-q9  (beyaz tabanlı siyah desen, Z=0.04)
         q1(-4.5,-1.5)  q2(-4.5,1.8)  q3(-2.5,1.8)  q4(-0.5,1.8)
         q5(0.7,0)      q6(2.2,0.6)
         q7(4.0,-2.0)   q8(4.0,0.0)   q9(4.0,2.0)   ← DÜZELTİLDİ
         ═══════════════════════════════════════════════════════════════════ -->
    <model name="qr_markers">
      <static>true</static>

      <!-- q1: ana rota, Başlangıç→D1 orta noktası -->
      <link name="q1">
        <pose>-4.5 -1.5 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q2: A1 yeşil şerit başlangıcı (Y=1.8) -->
      <link name="q2">
        <pose>-4.5 1.8 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q3: A2 yeşil şerit başlangıcı -->
      <link name="q3">
        <pose>-2.5 1.8 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q4: A3 yeşil şerit başlangıcı -->
      <link name="q4">
        <pose>-0.5 1.8 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q5: kapı durak noktası (kapıdan 0.8m önce, X=0.7) -->
      <link name="q5">
        <pose>0.7 0.0 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q6: D4→D5 dikey dal üzerinde (X=3.0, Y=0.6) — rota üzerinde -->
      <link name="q6">
        <pose>3.0 0.6 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q7: B3 kırmızı şerit başlangıcı  ← Y=-2.0 DÜZELTİLDİ (eski: Y=-1.5) -->
      <link name="q7">
        <pose>4.0 -2.0 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q8: B2 kırmızı şerit başlangıcı  ← Y=0.0  DÜZELTİLDİ (eski: Y=-0.5) -->
      <link name="q8">
        <pose>4.0 0.0 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>

      <!-- q9: B1 kırmızı şerit başlangıcı  ← Y=2.0  DÜZELTİLDİ (eski: Y=1.5) -->
      <link name="q9">
        <pose>4.0 2.0 0.04 0 0 0</pose>
        <visual name="base"><geometry><box><size>0.28 0.28 0.005</size></box></geometry><material><ambient>1 1 1 1</ambient><diffuse>1 1 1 1</diffuse></material></visual>
        <visual name="pat" ><pose>0 0 0.004 0 0 0</pose><geometry><box><size>0.20 0.20 0.004</size></box></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Kamera: tüm arena üstten görünür, hafif perspektif -->
    <gui fullscreen="0">
      <camera name="user_camera">
        <pose>-1 -14 12 0 0.70 1.5708</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
