        <visual   name="pallet_vis"><pose>0 0 0.055 0 0 0</pose><geometry><box><size>0.7 0.6 0.11</size></box></geometry><material><ambient>0.52 0.32 0.12 1</ambient><diffuse>0.52 0.32 0.12 1</diffuse></material></visual>
        <collision name="load_col"  ><pose>0 0 0.29  0 0 0</pose><geometry><box><size>0.5 0.42 0.36</size></box></geometry></collision>
