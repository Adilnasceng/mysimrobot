    <model name="pickup_station_backstops">
      <static>true</static>
      <link name="A1_bs"><pose>-4.5 3.75 0.5 0 0 0</pose><collision name="col"><geometry><box><size>1.0 0.10 1.0</size></box></geometry></collision><visual name="vis"><geometry><box><size>1.0 0.10 1.0</size></box></geometry><material><ambient>0.22 0.22 0.24 1</ambient><diffuse>0.22 0.22 0.24 1</diffuse></material></visual></link>
      <link name="A2_bs"><pose>-2.5 3.75 0.5 0 0 0</pose><collision name="col"><geometry><box><size>1.0 0.10 1.0</size></box></geometry></collision><visual name="vis"><geometry><box><size>1.0 0.10 1.0</size></box></geometry><material><ambient>0.22 0.22 0.24 1</ambient><diffuse>0.22 0.22 0.24 1</diffuse></material></visual></link>
